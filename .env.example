# ─────────────────────────────────────────────
# Umbral — Variables de entorno
# Copiar a .env.local y completar los valores
# ─────────────────────────────────────────────

# Site URL (sin trailing slash)
NEXT_PUBLIC_SITE_URL=https://umbral.studio

# WhatsApp Business — número con código de país, sin +
# Ejemplo: 5491112345678 (Argentina)
NEXT_PUBLIC_WHATSAPP_NUMBER=5491100000000

# Cal.com — link de agendamiento
NEXT_PUBLIC_CAL_LINK=https://cal.com/umbral/diagnostico

# Email de contacto visible
NEXT_PUBLIC_CONTACT_EMAIL=hola@umbral.studio

# ─── Formulario de contacto ─────────────────
# Opción A: Resend (recomendado)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@umbral.studio
RESEND_TO_EMAIL=hola@umbral.studio

# Opción B: Formspree (sin backend)
# NEXT_PUBLIC_FORMSPREE_ID=xxxxxxxxxxx

# ─── Analytics ──────────────────────────────
# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Vercel Analytics (se activa automáticamente en Vercel)
# No requiere variable — solo instalar @vercel/analytics

# ─── Lead magnet / Newsletter ────────────────
# ConvertKit / Kit
CONVERTKIT_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
CONVERTKIT_FORM_ID=0000000

# ─── Seguridad ──────────────────────────────
# Secret para verificar webhooks internos
WEBHOOK_SECRET=cambia_esto_por_un_secret_largo_y_aleatorio
